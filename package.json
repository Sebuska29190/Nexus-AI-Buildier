{
  "name": "agentforge",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run build:ui ; bun run packages/core/src/main.ts",
    "start": "bun run build:ui ; bun run packages/core/src/main.ts",
    "build:ui": "cd packages/ui ; bun run build",
    "build": "bun run build:ui",
    "test": "bun test packages/core/src/**/*.test.ts",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.9.0",
    "bun-types": "^1.3.14",
    "playwright": "^1.61.1"
  },
  "dependencies": {
    "hono": "^4.12.31",
    "vite": "^8.1.5",
    "ws": "^8.21.1"
  }
}
