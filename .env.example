# DeepSeek (required for default model)
DEEPSEEK_API_KEY=

# Anthropic (optional)
ANTHROPIC_API_KEY=

# OpenAI (optional)
OPENAI_API_KEY=

# Google Gemini (optional)
GEMINI_API_KEY=

# Ollama (optional, for local models)
OLLAMA_BASE_URL=http://localhost:11434

# Grok / xAI (optional)
GROK_API_KEY=

# Custom OpenAI-compatible endpoint (optional)
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL_NAME=

# Server
NOVA_PORT=4123
NOVA_HOST=127.0.0.1
NOVA_UI_DIR=./packages/ui/dist
NOVA_DB_PATH=./nova.db

# Optional: require API key authentication
# NOVA_AUTH_TOKEN=nv-...
